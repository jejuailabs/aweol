rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // 앱 공용 이미지 (학교 전경 등) — 읽기 공개, 쓰기 금지(콘솔/서버에서만)
    match /app-assets/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    // 작품 이미지 — 읽기 공개(전시), 업로드는 로그인 사용자 본인 경로에만
    match /artworks/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    /**
     * 숙제 제출물 — 본인 경로에만 업로드. 공개 여부는 Firestore 제출 문서가 통제한다.
     *
     * 영상은 사진과 상한이 다르다. 30초짜리도 한 반이면 450MB 라서
     * 무료 5GB 를 숙제 11개면 다 쓴다(실측). 20MB 로 묶어 대략 30초 720p 까지만 받는다.
     * 더 긴 영상은 유튜브에 올리고 주소를 내는 쪽(link)이 저장도 트래픽도 0이다.
     */
    match /homework/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && (
                     (request.resource.contentType.matches('image/.*')
                      && request.resource.size < 10 * 1024 * 1024)
                     || (request.resource.contentType.matches('video/.*')
                         && request.resource.size < 20 * 1024 * 1024)
                   );
    }

    // 퀴즈 문항에 붙이는 사진 — 출제자(교사) 본인 경로에만 업로드
    match /quiz/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // 틀린그림 찾기 사진 — 출제자(교사) 본인 경로에만
    match /spot/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    /**
     * 기억창고 JSON — 한 해 한 반의 전체 내용이 파일 하나에 들어 있다.
     * 읽기는 공개(졸업생도 봐야 한다), 쓰기는 서버(admin)만.
     * Firestore 에 수백 건으로 두는 것보다 읽기 요금이 훨씬 싸다.
     */
    match /archives/{schoolId}/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    // 그 외 전부 차단
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
