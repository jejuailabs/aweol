rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- 헬퍼 ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return isSignedIn() ? userData().role : null;
    }

    function isSuper() {
      return userRole() == 'super_admin';
    }

    /**
     * 학교를 특정할 수 없는 자리에서만 쓰는 전역 판정 (collectionGroup 등).
     * 민감한 데이터에는 쓰지 말 것 — 아래 isStaffOf 를 쓴다.
     */
    function isStaff() {
      return userRole() == 'teacher'
        || userRole() == 'school_admin'
        || userRole() == 'super_admin';
    }

    /**
     * 이 학교의 교직원인가.
     * 예전에는 role == 'teacher' 하나로 판정해서, 승인만 받으면 모든 학교의 명부와
     * 제출물을 볼 수 있었다. 교사 권한은 소속 학교 안에서만 통해야 한다.
     * get(키, 기본값)을 쓰는 이유: schoolIds 가 없는 옛 계정에서 규칙 평가가 실패하면 안 된다.
     */
    function isStaffOf(schoolId) {
      return isSignedIn()
        && (isSuper()
            || ((userRole() == 'teacher' || userRole() == 'school_admin')
                && schoolId in userData().get('schoolIds', [])));
    }

    /**
     * 이 학교의 **관리자**인가 (학교관리자 또는 총관리자).
     *
     * 교직원 판정보다 좁다. 반을 만들고 지우는 것처럼 **학교 전체 구성을 바꾸는 일**은
     * 담임 한 명이 정할 것이 아니다 — 한 사람이 3-4 반을 임의로 만들면
     * 실제 학교와 어긋나고, 이미 있는 반과 부딪힌다.
     */
    function isSchoolAdminOf(schoolId) {
      return isSignedIn()
        && (isSuper()
            || (userRole() == 'school_admin'
                && schoolId in userData().get('schoolIds', [])));
    }

    /**
     * 이 **반**의 담당 교사인가.
     * 학교 소속만으로는 부족하다 — 한 학교에 교사가 여럿인데 아무나 남의 반 명부를 보고
     * 숙제를 고칠 수 있으면 안 된다. 반 단위 자료는 전부 이걸 쓴다.
     */
    function isTeacherOf(schoolId, classId) {
      return isSignedIn()
        && (isSuper()
            || ((userRole() == 'teacher' || userRole() == 'school_admin')
                && schoolId in userData().get('schoolIds', [])
                && classId in userData().get('classIds', [])));
    }

    /**
     * 전시실 공개 범위 — **작품에 베껴둔 값으로 판정한다.**
     *
     * 여기(collectionGroup 자리)서는 경로를 쪼갤 수 없어서 어느 반 것인지 알 수 없고,
     * 전시실 문서를 `get()` 하면 작품 수만큼 읽기가 든다. 그래서 작품 문서가
     * `classId` 와 `visibility` 를 함께 지닌다.
     *
     * **`resource.data.get('visibility', 'school')` 로 쓰면 안 된다.**
     * 문서 하나를 읽을 때는 제대로 먹는데 **질의 판정에는 안 걸려서 그냥 통과시킨다**
     * (실측: 잠긴 작품이 비로그인 collectionGroup 조회에 그대로 딸려 왔다).
     * 기본값 있는 `get()` 은 질의의 `where` 와 맞춰볼 수 없기 때문으로 보인다.
     * 그래서 **필드를 직접 비교한다** — 대신 필드가 없는 문서는 평가가 실패해 막히므로
     * `scripts/backfill-artwork-scope.mjs` 로 옛 작품을 먼저 채워야 한다.
     */
    /**
     * 이 반 사람인가 — 아이·담임은 `classIds`, **학부모는 `childClassIds`**.
     * 규칙은 `children` 같은 객체 배열에서 classId 만 뽑아낼 수 없어서
     * 서버가 평평한 목록을 따로 적어준다(/api/student-code).
     */
    function inMyClasses(classId) {
      return isSignedIn()
             && (classId in userData().get('classIds', [])
                 || classId in userData().get('childClassIds', []));
    }

    function exhibitOpen() {
      return resource.data.visibility == 'school'
             || inMyClasses(resource.data.classId);
    }

    // ---------- 작품 (collectionGroup 조회용 — /gallery, /my-stand) ----------
    // 승인 + 공개 범위를 통과한 작품은 누구나(비로그인 포함) 조회 가능.
    // **조회 조건이 이 규칙과 정확히 같아야 한다** — 규칙이 열어준 것보다 넓게 물으면
    // 문서 하나가 막히는 순간 질의 전체가 실패한다(/gallery 참고).
    match /{path=**}/artworks/{artworkId} {
      allow read: if (resource.data.status == 'approved' && exhibitOpen())
                  || (isSignedIn()
                      && (resource.data.uploadedBy == request.auth.uid
                          || resource.data.artistUid == request.auth.uid))
                  || isStaff();
    }

    // ---------- 댓글 (collectionGroup 조회 대비) ----------
    match /{path=**}/comments/{commentId} {
      allow read: if true;
    }

    /**
     * 기억창고 (collectionGroup 조회용 — 교사 포트폴리오).
     * 중첩 규칙은 collectionGroup 질의에 적용되지 않아 여기에 따로 열어준다.
     * 아래 학교 경로에서도 이미 공개 읽기다.
     */
    match /{path=**}/archives/{archiveId} {
      allow read: if true;
    }

    // ---------- 활동 (collectionGroup 조회용 — /admin 학교 목록) ----------
    // 중첩 규칙은 collectionGroup 질의에 적용되지 않아 여기에 따로 열어준다.
    // 활동은 아래 학교 경로에서도 이미 공개 읽기다.
    match /{path=**}/activities/{activityId} {
      allow read: if true;
    }

    // ---------- 사용자 ----------
    match /users/{uid} {
      /**
       * 본인 문서와 총관리자만. 교사에게 열어주면 남의 학교 아이·학부모 정보까지 다 보인다.
       * 교사가 실제로 필요한 건 학교별 students 명부이고, 그건 아래에서 학교 단위로 열어준다.
       *
       * **예외 하나: 우리 학교에 교사 신청을 낸 사람.** 학교관리자가 승인하려면
       * 누가 신청했는지는 봐야 한다. 여는 범위는 딱 그만큼이다 —
       * `pendingRole == 'teacher'` 이고 신청 학교가 내 학교인 문서. 승인되면
       * pendingRole 이 지워지므로 **그 순간 다시 안 보인다.**
       */
      allow read: if isSignedIn()
                  && (request.auth.uid == uid
                      || isSuper()
                      || (resource.data.get('pendingRole', null) == 'teacher'
                          && isSchoolAdminOf(resource.data.get('pendingSchoolId', ''))));
      // 첫 로그인에 만드는 문서. 여기서 role 을 못 막으면 승인 게이트를 우회해
      // 처음부터 'teacher' 로 계정을 만들어버릴 수 있다.
      allow create: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.get('role', null) == null
                    && request.resource.data.get('pendingRole', null) == null
                    && request.resource.data.get('stamps', 0) == 0;
      // 권한(role)·도장 잔액·착용 아이템은 서버(/api/role, /api/shop, /api/homework)만 바꾼다.
      // role 이 열려 있으면 아무나 '선생님'을 써넣고 명부와 전 제출물을 열람할 수 있고,
      // stamps 가 열려 있으면 자기 문서에 9999 를 써넣고 상점을 털 수 있다.
      // get(키, 기본값)을 쓰는 이유: 이 기능들 이전에 만들어진 계정에는 해당 필드가 없고,
      // 없는 필드를 그냥 참조하면 규칙 평가가 실패해 아바타 선택·설정 저장까지 막힌다.
      allow update: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.get('role', null)
                       == resource.data.get('role', null)
                    && request.resource.data.get('pendingRole', null)
                       == resource.data.get('pendingRole', null)
                    && request.resource.data.get('classIds', [])
                       == resource.data.get('classIds', [])
                    && request.resource.data.get('stamps', 0)
                       == resource.data.get('stamps', 0)
                    && request.resource.data.get('avatarCustom', {})
                       == resource.data.get('avatarCustom', {});
      allow delete: if false;

      // 구매한 물건과 도장 내역 — 본인(과 교직원)만 보고, 쓰기는 서버만.
      match /inventory/{itemId} {
        allow read: if isSignedIn() && (request.auth.uid == uid || isSuper());
        allow write: if false;
      }

      match /stampLedger/{entryId} {
        allow read: if isSignedIn() && (request.auth.uid == uid || isSuper());
        allow write: if false;
      }

      /**
       * 선생님이 직접 만든 도장 도안.
       *
       * 본인만 만들고 지운다. 아이는 여기를 안 읽는다 — 찍는 순간 제출물 쪽으로
       * 그림 주소가 복사되므로, 선생님이 나중에 지워도 아이 도장은 남는다.
       * 잔액(stamps)과 달리 이건 '가진 개수'가 아니라 도안이라 서버를 안 거쳐도 된다.
       */
      match /stamps/{stampId} {
        allow read: if isSignedIn() && (request.auth.uid == uid || isSuper());
        allow create, update: if isSignedIn() && request.auth.uid == uid
                      && request.resource.data.label is string
                      && request.resource.data.label.size() <= 10
                      && request.resource.data.imageUrl is string;
        allow delete: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // ---------- 학교/학년/학급 ----------
    match /schools/{schoolId} {
      allow read: if true;              // 전시는 공개
      // 학교 생성·삭제는 총관리자만 (지도에 아무나 학교를 올릴 수 없다).
      // 교직원은 기존 학교의 정보만 손볼 수 있다.
      allow create, delete: if isSignedIn() && isSuper();
      // 학교 이름·대표 이미지는 학교 공용이라 담임 한 명이 바꾸면 안 된다
      allow update: if isSuper();

      /**
       * 현관 공지 — 학교 전체가 읽고, 그 학교 교직원이 쓴다.
       * 반 알림장(classes 아래 notices)과 다른 것이다. 이건 학교 단위.
       */
      match /hallNotices/{noticeId} {
        allow read: if true;
        allow write: if isStaffOf(schoolId);
      }

      /**
       * 건의함 — **공개가 아니다.**
       * 낸 본인과 그 학교 교직원만 읽는다. 전교생이 다 보는 게시판이면
       * 아이가 정작 하고 싶은 말을 못 쓴다.
       * 답변은 교직원만 달 수 있고, 본문은 낸 사람도 못 고친다(답변 뒤 말바꾸기 방지).
       */
      match /suggestions/{suggestionId} {
        allow read: if isStaffOf(schoolId)
                    || (isSignedIn() && resource.data.authorUid == request.auth.uid);
        allow create: if isSignedIn()
                      && request.resource.data.authorUid == request.auth.uid
                      && request.resource.data.get('reply', null) == null;
        allow update: if isStaffOf(schoolId);
        allow delete: if isStaffOf(schoolId)
                      || (isSignedIn() && resource.data.authorUid == request.auth.uid);
      }

      /**
       * 학교 동물 — 학교당 한 마리, 모두가 함께 돌본다.
       *
       * 돌보기(먹이·물·쓰다듬기)는 로그인한 사람이면 누구나. 대신 규칙이 두 가지를 잡는다.
       * 1) 이름과 종류는 교직원만 정한다 — 아무나 바꾸면 매일 이름이 달라진다.
       * 2) careCount 는 한 번에 1씩만 늘린다 — 안 막으면 9999를 써넣고 1등이 된다.
       */
      match /pet/{petId} {
        allow read: if true;
        allow create: if isStaffOf(schoolId);
        // 교직원은 이름·종류를 포함해 전부 고칠 수 있다
        allow update: if isStaffOf(schoolId)
                      || (isSignedIn()
                          && request.resource.data.kind == resource.data.kind
                          && request.resource.data.name == resource.data.name
                          && request.resource.data.careCount == resource.data.careCount + 1);
        allow delete: if isStaffOf(schoolId);
      }

      /**
       * 달리기 기록 — 순위표라 모두가 읽는다.
       * **쓰기는 서버만.** 시간을 서버가 재는데 클라이언트가 기록을 쓸 수 있으면
       * 서버에서 재는 의미가 없다. (/api/track 이 admin 으로 쓴다)
       */
      match /trackRecords/{uid} {
        allow read: if true;
        allow write: if false;
      }
      // 달리는 중인 판. 시작 시각이 들어 있어서 아예 안 보여준다.
      match /trackRuns/{uid} {
        allow read, write: if false;
      }

      /**
       * 짝맞추기 최고 점수 — 순위표라 읽기는 공개, 쓰기는 서버만.
       * 서버가 뒤집은 순서를 되짚어 점수를 낸다(/api/stage-play).
       */
      match /matchRecords/{uid} {
        allow read: if true;
        allow write: if false;
      }

      /**
       * 양궁 최고 기록 — 순위표라 읽기는 공개, 쓰기는 서버만.
       * 점수는 서버가 씨앗으로 다시 계산해서 낸다(/api/archery).
       */
      match /archeryRecords/{uid} {
        allow read: if true;
        allow write: if false;
      }
      // 쏘는 중인 판. 씨앗이 들어 있어서 아예 안 보여준다 —
      // 씨앗을 알면 바람과 흔들림을 미리 계산해 만점을 낼 수 있다.
      match /archeryRounds/{uid} {
        allow read, write: if false;
      }

      /**
       * 양궁 대결 방.
       *
       * 둘이 화면을 실시간으로 같이 보므로 **읽기는 로그인하면 열어둔다**
       * (참가 코드로 찾아 들어온다). 쓰기는 서버만 — 점수·차례를 서버가 정한다.
       * 씨앗도 여기 있지만, 대결은 순위표에 안 올라가고 상대도 같은 씨앗을 보므로
       * 미리 계산해봤자 상대도 똑같이 유리하다(혼자 하는 판과 다르다).
       */
      match /archeryDuels/{roomId} {
        allow read: if isSignedIn();
        allow write: if false;
      }

      /**
       * 기억창고 — 지나간 해의 반 요약.
       * 읽기는 공개(졸업생도 자기 반을 볼 수 있어야 한다), 쓰기는 서버만.
       * (/api/archive 가 admin 으로 쓴다)
       */
      match /archives/{archiveId} {
        allow read: if true;
        allow write: if false;
      }

      match /grades/{gradeId} {
        allow read: if true;
        allow write: if isStaffOf(schoolId);
      }

      // 명부 업로드 기록 (앱이 schools/{schoolId}/rosterUploads 아래에 쓴다)
      match /rosterUploads/{uploadId} {
        allow read, write: if isStaffOf(schoolId);
      }

      // 학생코드 역인덱스 — 읽기가 열리면 코드를 긁어 남의 반에 들어갈 수 있으므로
      // 클라이언트는 전혀 접근할 수 없고 서버(Admin SDK)만 다룬다.
      match /studentCodes/{code} {
        allow read, write: if false;
      }

      match /classes/{classId} {
        allow read: if true;
        // 반 정보(급훈·소개)는 담임이, 반 번호·보관 같은 구성은 학교관리자가 손본다.
        // 같은 문서라 필드로 못 가르므로 둘 다 열어둔다.
        allow update: if isTeacherOf(schoolId, classId) || isSchoolAdminOf(schoolId);
        /**
         * **반을 만들고 지우는 건 학교관리자만.**
         * 예전에는 학교 교직원 아무나 만들 수 있었다(create: isStaffOf). 그래서
         * 담임 한 명이 임의로 반을 늘릴 수 있었고, 실제 학교 구성과 어긋났다.
         * 반이 필요한 선생님은 학교관리자에게 요청한다.
         * (실제 만들기는 `/api/class` 가 하고, 여기 규칙은 그 우회로를 막는다)
         */
        allow create, delete: if isSchoolAdminOf(schoolId);

        // 학생 명부 — 미성년자 개인정보이므로 교직원만 열람·수정
        match /students/{studentId} {
          allow read, write: if isTeacherOf(schoolId, classId);
        }

        /**
         * 반 설정 — 지금은 **학생 로그인 비밀번호** 하나가 들어 있다.
         *
         * 반 문서(`classes/{id}`)는 `allow read: if true` 라 여기 두면 안 된다.
         * 담임만 읽고, **쓰기는 서버(`/api/student-password`)만** 한다 —
         * 열려 있으면 아이가 자기 반 비밀번호를 바꿔놓을 수 있다.
         */
        match /settings/{settingId} {
          allow read: if isTeacherOf(schoolId, classId);
          allow write: if false;
        }

        // 알림판 (알림장·급식·숙제·퀴즈) — 읽기는 공개, 작성은 교직원만
        match /notices/{noticeId} {
          allow read: if true;
          allow write: if isTeacherOf(schoolId, classId);

          // 로그인한 사람만 좋아요·댓글을 남길 수 있다
          match /likes/{likeUid} {
            allow read: if true;
            allow create, delete: if isSignedIn() && request.auth.uid == likeUid;
            allow update: if false;
          }

          match /comments/{commentId} {
            allow read: if true;
            allow create: if isSignedIn()
                          && request.resource.data.authorUid == request.auth.uid;
            allow update: if false;
            allow delete: if isTeacherOf(schoolId, classId)
                          || (isSignedIn() && resource.data.authorUid == request.auth.uid);
          }
        }

        // 숙제 — 과제 자체(제목·설명)는 공개, 출제는 교직원만
        match /homeworks/{hwId} {
          allow read: if true;
          allow write: if isTeacherOf(schoolId, classId);

          // 제출물은 서버(API)만 쓴다. AI 검수를 거치지 않고는 올라올 수 없게 한다.
          // 읽기: 교직원 / 본인 / '아이들과 함께 보기'로 공개된 승인 제출물
          match /submissions/{studentUid} {
            allow read: if isTeacherOf(schoolId, classId)
                        || (isSignedIn() && request.auth.uid == studentUid)
                        || resource.data.publicToClass == true;
            allow write: if false;
          }

          /**
           * 열어본 기록 — 교직원과 본인만 본다.
           * 누가 봤는지 아이들끼리 알 필요가 없다.
           *
           * **create 만 허용하고 update 를 막는다.** 열 때마다 덮어쓰면
           * '처음 언제 봤나' 가 사라지고, 아이가 스무 번 열면 스무 번 쓴다.
           */
          match /reads/{studentUid} {
            allow read: if isTeacherOf(schoolId, classId)
                        || (isSignedIn() && request.auth.uid == studentUid);
            allow create: if isSignedIn()
                          && request.auth.uid == studentUid
                          && request.resource.data.studentUid == studentUid;
            allow update: if false;
            allow delete: if isTeacherOf(schoolId, classId);
          }

          // 콕 찌르기 — 찔린 본인과 교직원만 본다. 친구가 누가 안 냈는지 훑어볼 수 없어야 한다.
          match /nudges/{studentUid} {
            allow read: if isTeacherOf(schoolId, classId) || (isSignedIn() && request.auth.uid == studentUid);
            allow write: if false;
          }
        }

        // 퀴즈 — 문제는 공개, 정답은 절대 공개하지 않는다.
        match /quizzes/{quizId} {
          allow read: if true;
          allow write: if isTeacherOf(schoolId, classId);

          // 문항(지문·보기)만 공개. 정답 필드는 여기 두지 않는다 —
          // 두는 순간 개발자도구로 그냥 보인다.
          match /questions/{qId} {
            allow read: if true;
            allow write: if false;
          }

          // 정답. 학생이 읽으면 퀴즈가 성립하지 않는다. 채점은 서버가 한다.
          match /answerKeys/{qId} {
            allow read: if isTeacherOf(schoolId, classId);
            allow write: if false;
          }

          // 제출물 — 교직원 / 본인 / 공개된 것
          match /submissions/{studentUid} {
            allow read: if isTeacherOf(schoolId, classId)
                        || (isSignedIn() && request.auth.uid == studentUid)
                        || resource.data.publicToClass == true;
            allow write: if false;
          }
        }

        // 틀린그림 찾기 — 그림은 공개, 정답 좌표는 절대 공개하지 않는다.
        /**
         * 게임 스테이지 — 그날 배운 낱말 묶음.
         *
         * 읽기는 로그인한 사람이면 된다(아이가 놀아야 한다).
         * 쓰기는 이 반 담임만.
         * 낱말 쌍은 게임의 재료라 숨길 정답이 따로 없다 — 퀴즈와 다르다.
         */
        match /stages/{stageId} {
          allow read: if isSignedIn();
          allow write: if isTeacherOf(schoolId, classId);

          /*
            아이가 한 판 한 기록.
            점수가 학교 랭킹에 오르므로 **서버만 쓴다**(/api/stage-play).
            전에는 본인이 직접 썼는데, 그러면 아무 점수나 적어 보낼 수 있다.
          */
          match /plays/{playId} {
            allow read: if isSignedIn();
            allow write: if false;
          }
        }

        match /spotGames/{gameId} {
          allow read: if true;
          allow write: if false;   // 서버(API)만

          // 정답 좌표. 학생이 읽으면 게임이 성립하지 않는다. 판정도 서버가 한다.
          match /answerKey/{docId} {
            allow read: if isTeacherOf(schoolId, classId);
            allow write: if false;
          }

          // 풀이 기록 — 순위표를 함께 보여줘야 하므로 읽기는 공개.
          // (기록에는 이름·시간만 들어가고 정답 좌표는 없다)
          match /plays/{studentUid} {
            allow read: if true;
            allow write: if false;
          }
        }

        // 칠판 낙서 — 읽기는 공개, 쓰기는 서버(Admin SDK)만.
        // 클라이언트가 직접 쓰지 못하게 막아야 작성자 위조와 IP 누락을 방지할 수 있다.
        match /blackboard/{itemId} {
          allow read: if true;
          allow write: if false;
        }

        match /activities/{activityId} {
          allow read: if true;
          allow write: if isTeacherOf(schoolId, classId);

          match /artworks/{artworkId} {
            /**
             * 승인된 작품은 공개, 미승인은 작성자(업로더/작가)와 교사만.
             *
             * **'우리 반만' 전시실은 여기서도 막아야 한다.** 위 collectionGroup 규칙만
             * 조이면 주소를 아는 사람은 전시실을 그대로 열 수 있다 — 규칙은 하나라도
             * 통과하면 허용이라, 두 자리를 같이 닫지 않으면 닫은 게 아니다.
             * 여기서는 경로에 반이 있으므로 반 사람인지 바로 볼 수 있다.
             */
            allow read: if (resource.data.status == 'approved'
                            && (resource.data.visibility == 'school'
                                || inMyClasses(classId)))
                        || isTeacherOf(schoolId, classId)
                        || (isSignedIn()
                            && (resource.data.uploadedBy == request.auth.uid
                                || resource.data.artistUid == request.auth.uid));
            // 학생/학부모/교사가 업로드 (항상 pending으로 생성)
            allow create: if isSignedIn()
                          && request.resource.data.uploadedBy == request.auth.uid
                          && (isTeacherOf(schoolId, classId) || request.resource.data.status == 'pending');
            // 승인/반려는 교사만, 본인은 pending 상태에서 내용 수정 가능
            allow update: if isTeacherOf(schoolId, classId)
                          || (isSignedIn()
                              && resource.data.uploadedBy == request.auth.uid
                              && resource.data.status == 'pending'
                              && request.resource.data.status == 'pending');
            allow delete: if isTeacherOf(schoolId, classId)
                          || (isSignedIn() && resource.data.uploadedBy == request.auth.uid);

            match /comments/{commentId} {
              allow read: if true;
              allow create: if isSignedIn()
                            && request.resource.data.authorUid == request.auth.uid;
              allow update: if false;
              allow delete: if isTeacherOf(schoolId, classId)
                            || (isSignedIn() && resource.data.authorUid == request.auth.uid);
            }

            match /likes/{likeUid} {
              allow read: if true;
              allow create, delete: if isSignedIn() && request.auth.uid == likeUid;
              allow update: if false;
            }
          }
        }
      }
    }

    // ---------- 접근 기록 (계정 도용 추적) ----------
    // IP가 담긴 민감 정보이므로 슈퍼 관리자만 열람. 쓰기는 서버만.
    match /accessLogs/{logId} {
      allow read: if isSignedIn() && isSuper();
      allow write: if false;
    }

    // 그 외 전부 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
